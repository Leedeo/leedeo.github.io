---
layout: null
---
[{% for post in site.posts %}{% assign post_author = site.data.authors[post.author] %}{% unless post_author %}{% assign post_author = site.data.authors['javo'] %}{% endunless %}{"title":{{ post.title | jsonify }},"url":{{ post.url | relative_url | jsonify }},{% assign months = "enero,febrero,marzo,abril,mayo,junio,julio,agosto,septiembre,octubre,noviembre,diciembre" | split: "," %}{% assign m_idx = post.date | date: "%m" | plus: 0 | minus: 1 %}{% capture post_date_str %}{{ post.date | date: "%-d" }} de {{ months[m_idx] }} de {{ post.date | date: "%Y" }}{% endcapture %}"date":{{ post_date_str | jsonify }},"excerpt":{{ post.excerpt | strip_html | truncate: 200 | jsonify }},"thumbnail":{{ post.thumbnail | relative_url | jsonify }},"categories":{{ post.categories | join: "," | jsonify }},"authorName":{{ post_author.name | jsonify }},"authorAvatar":{{ post_author.avatar | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
