---
layout: null
---
[{% for post in site.posts %}{% assign post_author = site.data.authors[post.author] %}{% unless post_author %}{% assign post_author = site.data.authors['javo'] %}{% endunless %}{% assign months = "enero,febrero,marzo,abril,mayo,junio,julio,agosto,septiembre,octubre,noviembre,diciembre" | split: "," %}{% assign month_index = post.date | date: "%m" | plus: 0 | minus: 1 %}{% capture date_localized %}{{ post.date | date: "%-d" }} de {{ months[month_index] }} de {{ post.date | date: "%Y" }}{% endcapture %}{"title":{{ post.title | jsonify }},"url":{{ post.url | relative_url | jsonify }},"date":{{ date_localized | jsonify }},"excerpt":{{ post.excerpt | strip_html | truncate: 200 | jsonify }},"thumbnail":{{ post.thumbnail | relative_url | jsonify }},"categories":{{ post.categories | join: ", " | jsonify }},"author":{{ post.author | default: 'javo' | jsonify }},"authorName":{{ post_author.name | jsonify }},"authorAvatar":{{ post_author.avatar | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
